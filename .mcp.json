{
  "mcpServers": {
    "fastcontext": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Scratchydisk/fastcontext-agent-tools@main",
        "fastcontext-mcp"
      ],
      "env": {
        "BASE_URL": "http://127.0.0.1:11434/v1",
        "MODEL": "fc-q4-nothink-16k:latest",
        "API_KEY": "ollama",
        "FASTCONTEXT_ALLOWED_ROOTS": "/",
        "FC_MAX_TOKENS": "4096",
        "FC_TEMPERATURE": "0.2",
        "FASTCONTEXT_EXPLORE_RETRIES": "2",
        "FASTCONTEXT_REROOT_PATHS": "1"
      }
    }
  }
}
