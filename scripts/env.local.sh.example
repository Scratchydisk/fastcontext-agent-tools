# Template for scripts/env.local.sh -- copy it and edit:
#
#     cp scripts/env.local.sh.example scripts/env.local.sh
#
# env.local.sh is gitignored and sourced last by env.sh, so anything here wins
# over the committed defaults. Everything below is OFF by default; uncomment
# only what your setup needs. Larger GPUs running full-precision generally need
# nothing here except perhaps FASTCONTEXT_ALLOWED_ROOTS.

# ===========================================================================
# Small-GPU recipe (verified on an 8GB RTX A2000). Uncomment this whole block
# to run FastContext-4B on a card that can't hold the BF16 weights (~8GB).
# ===========================================================================

# 4-bit in-flight quantisation -- BF16 weights (~8GB) won't fit in 8GB and OOM
# while loading, before the KV cache. 4-bit drops them to ~2.5GB.
# export QUANT="bitsandbytes"

# Small KV cache. Bump up (32768, then 65536) if the card has headroom; the
# model supports up to 262144.
# export CTX_LEN="16384"

# Leave VRAM headroom for the CUDA context and skip CUDA-graph capture --
# otherwise startup OOMs *after* the weights load on a tight card.
# export GPU_MEM_UTIL="0.85"
# export ENFORCE_EAGER="1"

# Fall back to the PyTorch-native sampler if flashinfer's bundled sampling
# kernel won't JIT-compile against your CUDA toolkit (attention still uses
# FLASH_ATTN on Ampere). Symptom: "CUB ... has no member FlagHeads" at startup.
# export VLLM_USE_FLASHINFER_SAMPLER="0"

# Cap FastContext's output tokens (native env var, default 4096). vLLM enforces
# prompt_tokens + max_tokens <= CTX_LEN, and the agent's prompt grows as it
# reads files, so keep this well under CTX_LEN to leave reading room. ~4000 is
# plenty for the (short) final answer while leaving ~12k of a 16384 window.
# export FC_MAX_TOKENS="4000"

# Re-root paths a heavily-quantised model mangles (it truncates "/mnt/.../repo"
# to "/repo", so every search lands outside the workspace). Only needed for
# degraded/quantised models; leave unset for full-precision models so they keep
# the strict upstream path handling.
# export FASTCONTEXT_REROOT_PATHS="1"

# Pin a specific GPU (skips serve-model.sh's interactive prompt). Index, a comma
# list (0,1), or "all".
# export GPU="0"

# ===========================================================================
# General settings (any GPU)
# ===========================================================================

# Which repos explore may target. Defaults (in env.sh) to the repo's parent
# dir. Set to "/" to allow any path so FastContext can be pointed anywhere.
# This is only the repo_path guard, not the in-run sandbox.
# export FASTCONTEXT_ALLOWED_ROOTS="/"

# Hugging Face token, if the model download needs auth.
# export HF_TOKEN="hf_..."

# Point the MCP server at a remote endpoint instead of local vLLM.
# export BASE_URL="https://your-endpoint/v1"
# export API_KEY="..."
